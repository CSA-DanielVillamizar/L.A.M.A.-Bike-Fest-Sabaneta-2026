generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

model ClubRegistration {
  id                 String   @id @default(uuid())
  clubName           String
  presidentName      String
  motorcycleType     String
  estimatedAttendees Int
  originCity         String
  country            String?
  createdAt          DateTime @default(now())
  contactPhone       String
  isPaid             Boolean  @default(false)
}

model SponsorRegistration {
  id           String   @id @default(uuid())
  companyName  String
  category     String
  country      String?
  interests    String
  contactEmail String
  contactPhone String
  createdAt    DateTime @default(now())
}

model OfficialRegistration {
  id                  String      @id @default(uuid())
  participantCategory String
  fullName            String
  documentId          String
  eps                 String
  emergencyName       String
  emergencyPhone      String
  country             String?
  chapter             String
  isDirective         Boolean     @default(false)
  directiveScope      String?
  directiveRole       String?
  arrivalDate         String
  medicalCondition    String?
  wantsJersey         Boolean     @default(false)
  jerseySize          String?
  hasCompanions       Boolean     @default(false)
  companionsCount     Int         @default(0)
  totalToPay          Float
  paymentStatus       String      @default("PENDING")
  createdAt           DateTime    @default(now())
  isPaid              Boolean     @default(false)
  companions          Companion[]
}

model Companion {
  id             String               @id @default(uuid())
  registrationId String
  fullName       String
  documentId     String
  category       String
  wantsJersey    Boolean              @default(false)
  jerseySize     String?
  registration   OfficialRegistration @relation(fields: [registrationId], references: [id])
}
