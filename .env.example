# Copia este archivo a .env y completa los valores reales.
# NUNCA subas el archivo .env al repositorio — está en .gitignore.

# Cadena de conexión a Azure SQL Database (SQL Server)
# Formato: sqlserver://<servidor>.database.windows.net:1433;database=<db>;user=<usuario>;password=<contraseña>;encrypt=true;trustServerCertificate=false;loginTimeout=30;
DATABASE_URL="sqlserver://<nombre-servidor>.database.windows.net:1433;database=<nombre-db>;user=<usuario>;password=<contraseña>;encrypt=true;trustServerCertificate=false;loginTimeout=30;"
