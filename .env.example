# Copia este archivo a .env.local y completa los valores reales.
# NUNCA subas el archivo .env.local al repositorio — está en .gitignore.

# Cadena de conexión a Azure SQL Database (SQL Server)
# Formato: sqlserver://<servidor>.database.windows.net:1433;database=<db>;user=<usuario>;password=<contraseña>;encrypt=true;trustServerCertificate=false;loginTimeout=30;
DATABASE_URL="sqlserver://<nombre-servidor>.database.windows.net:1433;database=<nombre-db>;user=<usuario>;password=<contraseña>;encrypt=true;trustServerCertificate=false;loginTimeout=30;"

# Contraseña para acceso al dashboard administrativo (Centro de Mando)
# Esta contraseña será solicitada en /centro-de-mando
# Recomendado: variable de servidor (no pública)
ADMIN_ACCESS_PASSWORD="tu-contraseña-segura-aqui"
# Compatibilidad legacy (fallback):
NEXT_PUBLIC_ADMIN_ACCESS_PASSWORD="tu-contraseña-segura-aqui"
